# =============================================================================
# Worker environment — NEVER commit real values. Set these in Railway.
# =============================================================================

# Supabase (server-side only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Binance Spot TESTNET credentials (create at https://testnet.binance.vision)
# NEVER use mainnet keys. NEVER enable withdrawal permissions.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Binance Spot Testnet endpoints (defaults shown)
BINANCE_BASE_URL=https://testnet.binance.vision
BINANCE_WS_URL=wss://stream.testnet.binance.vision

# Safety switches
# PAPER_TRADING=true forces the simulated broker for ALL bots (default: true)
PAPER_TRADING=true
# KILL_SWITCH=true blocks all order creation and bot starts globally
KILL_SWITCH=false

# Runtime
PORT=8080
LOG_LEVEL=info
WORKER_INSTANCE_ID=worker-1
