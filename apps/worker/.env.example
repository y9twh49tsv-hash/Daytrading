# =============================================================================
# Worker environment — NEVER commit real values. Set these in Railway.
# =============================================================================

# Supabase (server-side only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Binance Spot TESTNET credentials (create at https://testnet.binance.vision)
# NEVER use mainnet keys. NEVER enable withdrawal permissions.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Binance Spot Testnet endpoints (defaults shown)
BINANCE_BASE_URL=https://testnet.binance.vision
BINANCE_WS_URL=wss://stream.testnet.binance.vision

# -----------------------------------------------------------------------------
# LIVE (mainnet) trading with REAL funds — only used by bots with mode=live.
# Leave everything below empty/false unless you deliberately want real trading.
# -----------------------------------------------------------------------------
# Separate mainnet credentials (create at https://www.binance.com, API Management).
# Enable ONLY "Spot Trading". NEVER enable withdrawals. Restrict to your egress IP.
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_API_SECRET=
BINANCE_LIVE_BASE_URL=https://api.binance.com
BINANCE_LIVE_WS_URL=wss://stream.binance.com:9443

# Safety switches
# PAPER_TRADING=true forces the simulated broker for ALL bots (default: true).
# Must be false for testnet or live bots to place real (test/real) orders.
PAPER_TRADING=true
# ALLOW_LIVE_TRADING=true is REQUIRED before any bot may trade real money.
# Live also requires PAPER_TRADING=false and KILL_SWITCH=false.
ALLOW_LIVE_TRADING=false
# KILL_SWITCH=true blocks all order creation and bot starts globally
KILL_SWITCH=false

# Runtime
PORT=8080
LOG_LEVEL=info
WORKER_INSTANCE_ID=worker-1
