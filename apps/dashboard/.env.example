# =============================================================================
# Dashboard environment — set these in Vercel. NEVER commit real values.
#
# NEXT_PUBLIC_* variables are exposed to the browser. They must ONLY contain
# the Supabase URL and the anon (public) key — never any secret.
# Binance API keys DO NOT belong here under any circumstances.
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Only needed if a server-side admin task requires it. Not used by default.
# NEVER prefix this with NEXT_PUBLIC.
# SUPABASE_SERVICE_ROLE_KEY=
